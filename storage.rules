rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Videolar: sadece sahibi yükleyebilir, herkes okuyabilir
    match /videos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 200 * 1024 * 1024  // maks 200 MB
                   && request.resource.contentType.matches('video/.*');
    }

    // Profil fotoğrafları
    match /profiles/{userId}/avatar.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024   // maks 5 MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
